  <bpmn:process id="process_1" isExecutable="true">
    <bpmn:startEvent id="start_1" name="Start">
      <bpmn:outgoing>flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="task_1" name="Check Health Check Data Availability">
      <bpmn:extensionElements>
        <spiffworkflow:serviceTaskOperator id="op_task_1" resultVariable="check_health_check_data_availability">
          <spiffworkflow:parameters>
            <spiffworkflow:parameter id="param_1" type="str" value="Health_Check" />
          </spiffworkflow:parameters>
        </spiffworkflow:serviceTaskOperator>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_1</bpmn:incoming>
      <bpmn:outgoing>flow_2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gateway_1" name="Verify Health Check Performed" default="flow_4">
      <bpmn:incoming>flow_2</bpmn:incoming>
      <bpmn:outgoing>flow_3</bpmn:outgoing>
      <bpmn:outgoing>flow_4</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_2" name="Exclude Record Due to Missing Health Check">
      <bpmn:extensionElements>
        <spiffworkflow:serviceTaskOperator id="op_task_2" resultVariable="exclude_record_due_to_missing_health_check">
          <spiffworkflow:parameters>
            <spiffworkflow:parameter id="param_1" type="str" value="Health_Check" />
          </spiffworkflow:parameters>
        </spiffworkflow:serviceTaskOperator>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_4</bpmn:incoming>
      <bpmn:outgoing>flow_5</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="end_1" name="End - No Health Check Data">
      <bpmn:incoming>flow_5</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="task_3" name="Screen Clinical Exclusion Criteria">
      <bpmn:extensionElements>
        <spiffworkflow:serviceTaskOperator id="op_task_3" resultVariable="screen_clinical_exclusion_criteria">
          <spiffworkflow:parameters>
            <spiffworkflow:parameter id="param_1" type="str" value="Type_1_Diabetes" />
          </spiffworkflow:parameters>
        </spiffworkflow:serviceTaskOperator>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_3</bpmn:incoming>
      <bpmn:outgoing>flow_6</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gateway_2" name="Check Program Exclusion" default="flow_8">
      <bpmn:incoming>flow_6</bpmn:incoming>
      <bpmn:outgoing>flow_7</bpmn:outgoing>
      <bpmn:outgoing>flow_8</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_4" name="Exclude Individual from Program">
      <bpmn:extensionElements>
        <spiffworkflow:serviceTaskOperator id="op_task_4" resultVariable="exclude_individual_from_program">
          <spiffworkflow:parameters>
            <spiffworkflow:parameter id="param_1" type="str" value="Cancer" />
          </spiffworkflow:parameters>
        </spiffworkflow:serviceTaskOperator>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_7</bpmn:incoming>
      <bpmn:outgoing>flow_9</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="end_2" name="End - Excluded Clinically">
      <bpmn:incoming>flow_9</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="task_5" name="Assess Eligibility for Quantitative Urinary Albumin Test">
      <bpmn:extensionElements>
        <spiffworkflow:serviceTaskOperator id="op_task_5" resultVariable="assess_eligibility_for_quantitative_urinary_albumin_test">
          <spiffworkflow:parameters>
            <spiffworkflow:parameter id="param_1" type="str" value="Age" />
          </spiffworkflow:parameters>
        </spiffworkflow:serviceTaskOperator>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_8</bpmn:incoming>
      <bpmn:outgoing>flow_10</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gateway_3" name="Evaluate Eligibility for Urinary Albumin Test" default="flow_12">
      <bpmn:incoming>flow_10</bpmn:incoming>
      <bpmn:outgoing>flow_11</bpmn:outgoing>
      <bpmn:outgoing>flow_12</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_6" name="Issue Ticket for Quantitative Urinary Albumin Test">
