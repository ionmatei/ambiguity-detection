        <spiffworkflow:serviceTaskOperator id="op_task_6" resultVariable="issue_ticket_for_quantitative_urinary_albumin_test">
          <spiffworkflow:parameters>
            <spiffworkflow:parameter id="param_1" type="str" value="Urine_lbumin" />
          </spiffworkflow:parameters>
