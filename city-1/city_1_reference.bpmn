  <bpmn:process id="process_1" isExecutable="true">
    <bpmn:startEvent id="start_1">
      <bpmn:outgoing>flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="task_1" name="Verify Health Check Data">
      <bpmn:extensionElements>
        <spiffworkflow:serviceTaskOperator id="op_task_1" resultVariable="verify_health_check_data">
          <spiffworkflow:parameters>
            <spiffworkflow:parameter id="param_1" type="str" value="Health_Check" />
          </spiffworkflow:parameters>
        </spiffworkflow:serviceTaskOperator>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_1</bpmn:incoming>
      <bpmn:outgoing>flow_2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gateway_1" name="Check Health Check Availability" default="flow_4">
      <bpmn:incoming>flow_2</bpmn:incoming>
      <bpmn:outgoing>flow_3</bpmn:outgoing>
      <bpmn:outgoing>flow_4</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_2" name="Check Cancer Exclusion">
      <bpmn:extensionElements>
        <spiffworkflow:serviceTaskOperator id="op_task_2" resultVariable="check_cancer_exclusion">
          <spiffworkflow:parameters>
            <spiffworkflow:parameter id="param_1" type="str" value="Cancer" />
          </spiffworkflow:parameters>
        </spiffworkflow:serviceTaskOperator>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_3</bpmn:incoming>
      <bpmn:outgoing>flow_5</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gateway_2" name="Evaluate Cancer Exclusion" default="flow_7">
      <bpmn:incoming>flow_5</bpmn:incoming>
      <bpmn:outgoing>flow_6</bpmn:outgoing>
      <bpmn:outgoing>flow_7</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_3" name="Assess Clinical Eligibility">
      <bpmn:extensionElements>
        <spiffworkflow:serviceTaskOperator id="op_task_3" resultVariable="assess_clinical_eligibility">
          <spiffworkflow:parameters>
            <spiffworkflow:parameter id="param_1" type="str" value="Type_2_Diabetes_Prior_Year_Jan_to_Dec" />
          </spiffworkflow:parameters>
        </spiffworkflow:serviceTaskOperator>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_7</bpmn:incoming>
      <bpmn:outgoing>flow_8</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gateway_3" name="Check Clinical Eligibility" default="flow_10">
      <bpmn:incoming>flow_8</bpmn:incoming>
      <bpmn:outgoing>flow_9</bpmn:outgoing>
      <bpmn:outgoing>flow_10</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_4" name="Notify Health Guidance Eligibility">
