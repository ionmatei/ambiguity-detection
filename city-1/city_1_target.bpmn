        <spiffworkflow:serviceTaskOperator id="op_task_5" resultVariable="provide_health_guidance_sessions">
          <spiffworkflow:parameters>
            <spiffworkflow:parameter id="param_1" type="int" value="6" />
          </spiffworkflow:parameters>
        </spiffworkflow:serviceTaskOperator>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_12</bpmn:incoming>
      <bpmn:outgoing>flow_14</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_6" name="Conduct Post-Implementation Follow-Up">
      <bpmn:extensionElements>
        <spiffworkflow:serviceTaskOperator id="op_task_6" resultVariable="conduct_post_implementation_follow_up">
          <spiffworkflow:parameters>
            <spiffworkflow:parameter id="param_1" type="str" value="&#39;follow_up&#39;" />
          </spiffworkflow:parameters>
        </spiffworkflow:serviceTaskOperator>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_14</bpmn:incoming>
      <bpmn:outgoing>flow_15</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="end_1">
