      <bpmn:outgoing>flow_9</bpmn:outgoing>
      <bpmn:outgoing>flow_10</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_4" name="Notify Health Guidance Eligibility">
      <bpmn:extensionElements>
        <spiffworkflow:serviceTaskOperator id="op_task_4" resultVariable="notify_health_guidance_eligibility">
          <spiffworkflow:parameters>
            <spiffworkflow:parameter id="param_1" type="str" value="&#39;notification&#39;" />
          </spiffworkflow:parameters>
        </spiffworkflow:serviceTaskOperator>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_9</bpmn:incoming>
      <bpmn:outgoing>flow_11</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gateway_4" name="Check Health Guidance Acceptance" default="flow_13">
      <bpmn:incoming>flow_11</bpmn:incoming>
      <bpmn:outgoing>flow_12</bpmn:outgoing>
      <bpmn:outgoing>flow_13</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_5" name="Provide Health Guidance Sessions">
